import gradio as gr
import ast

def quick_sort_music(playlist):
    # Base case: A list of 0 or 1 elements is already sorted
    if len(playlist) <= 1:
        return playlist
    
    # Pick middle element as the pivot
    pivot = playlist[len(playlist) // 2]
    
    left = []
    middle = []
    right = []
    
    for song in playlist:
        # Sort by Genre first (Alphabetical)
        if song['genre'] < pivot['genre']:
            left.append(song)
        elif song['genre'] > pivot['genre']:
            right.append(song)
        else:
            # If genres match, sort by Energy (Highest to Lowest)
            if song['energy'] > pivot['energy']:
                left.append(song)
            elif song['energy'] < pivot['energy']:
                right.append(song)
            else:
                middle.append(song)
                
    # Combine sub-lists using recursion
    return quick_sort_music(left) + middle + quick_sort_music(right)

def validate_and_sort(songs):
    # Precondition check: verify data exists and energy is 0-100
    for song in songs:
        if not song.get('genre') or song.get('energy') is None:
            return "Error: Missing song data."
        
        if not (0 <= song['energy'] <= 100):
            return "Error: Invalid energy score."

    return quick_sort_music(songs)

# Gradio UI

def ui_wrapper(raw_input):
    try:
        # Convert text input into a Python list of dictionaries
        songs = ast.literal_eval(raw_input)
        
        # Run validation and sorting
        result = validate_and_sort(songs)
        
        # If result is an error string, return it; otherwise, format the list
        if isinstance(result, str):
            return result
        
        formatted_output = "--- Your Optimized Playlist ---\n\n"
        for s in result:
            formatted_output += f"[{s['genre'].upper()}] {s.get('title', 'Unknown')} - Energy: {s['energy']}\n"
        return formatted_output
        
    except Exception:
        return "Input Error: Ensure you use the correct list format."

# Setup the interface
interface = gr.Interface(
    fn=ui_wrapper, 
    inputs=gr.Textbox(lines=5, label="Paste Song Data Here", placeholder="[{'title': 'Song 1', 'genre': 'Rock', 'energy': 80}, ...]"),
    outputs=gr.Textbox(label="Sorted Vibe Results"),
    title="🎵 Playlist Vibe Builder",
    description="Sorts your music by Genre (A-Z) and then by Energy (High-Low) using Quick Sort."
)

if __name__ == "__main__":
    interface.launch()
